generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Source {
  WEB
  DISCORD
  SLACK
  AGENT
}

model Workspace {
  id                    String    @id @default(cuid())
  name                  String
  discordGuildId        String?
  discordChannelId      String?
  dailyDigestTime       String    @default("08:30")
  archiveDoneAfterDays  Int       @default(7)
  timezone              String    @default("America/Los_Angeles")
  notesbotLastPolledAt  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  boards                Board[]

  @@index([discordGuildId])
}

model User {
  id            String       @id @default(cuid())
  name          String       @unique
  email         String?      @unique
  discordUserId String?      @unique
  slackUserId   String?      @unique
  role          UserRole     @default(MEMBER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  assignedTasks Task[]       @relation("TaskAssignee")
  createdTasks  Task[]       @relation("TaskCreator")
  comments      TaskComment[]
}

model Board {
  id          String        @id @default(cuid())
  name        String
  workspaceId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns     BoardColumn[]
  tasks       Task[]

  @@index([workspaceId])
}

model BoardColumn {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([boardId, name])
  @@index([boardId, position])
}

model Task {
  id               String        @id @default(cuid())
  boardId          String
  columnId         String
  title            String
  description      String?
  assigneeId       String?
  createdById      String?
  priority         Priority      @default(MEDIUM)
  dueDate          DateTime?
  isBlocked        Boolean       @default(false)
  blockerReason    String?
  source           Source        @default(WEB)
  sourceMessageUrl String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  completedAt      DateTime?
  archivedAt       DateTime?
  board            Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column           BoardColumn   @relation(fields: [columnId], references: [id])
  assignee         User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy        User?         @relation("TaskCreator", fields: [createdById], references: [id])
  comments         TaskComment[]

  @@index([boardId, columnId])
  @@index([boardId, archivedAt])
  @@index([assigneeId])
  @@index([dueDate])
}

model PollLog {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  callsFound     Int
  callsNew       Int
  tasksExtracted Int
  errorMessage   String?

  @@index([createdAt(sort: Desc)])
}

enum PendingTaskStatus {
  PENDING
  APPROVED
  REJECTED
}

model MeetingCall {
  id               String        @id @default(cuid())
  notesbotCallId   String        @unique
  serverName       String
  channelName      String
  durationSeconds  Int
  participantCount Int
  summary          String        @db.Text
  transcript       String        @db.Text
  recordedAt       DateTime
  processedAt      DateTime      @default(now())
  pendingTasks     PendingTask[]
}

model PendingTask {
  id            String            @id @default(cuid())
  meetingCallId String
  meetingCall   MeetingCall       @relation(fields: [meetingCallId], references: [id])
  title         String
  description   String?           @db.Text
  assigneeName  String?
  priority      Priority          @default(MEDIUM)
  status        PendingTaskStatus @default(PENDING)
  taskId        String?           @unique
  createdAt     DateTime          @default(now())
  reviewedAt    DateTime?

  @@index([status])
  @@index([meetingCallId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String?
  body      String
  source    Source   @default(WEB)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
}

